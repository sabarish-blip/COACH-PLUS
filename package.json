{
  "name": "novax",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "postinstall": "npm run install:all",
    "backend": "npm --prefix backend run server",
    "backend:dev": "npm --prefix backend run dev",
    "frontend": "npm --prefix frontend exec vite",
    "frontend:dev": "npm --prefix frontend exec vite",
    "build": "npm --prefix frontend run build"
  }
}
